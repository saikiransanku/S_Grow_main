DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ORIGIN=*

# Seasonal inference artifacts
SEASONAL_RUNS_DIR=C:/AI_Preditions/training/image_prediction/runs
ALL_SEASON_MODEL_PATH=C:/AI_Preditions/training/image_prediction/runs/all_season/ssgrow_disease_model_v2.keras
ALL_SEASON_CLASS_FILE=C:/AI_Preditions/training/image_prediction/runs/all_season/class_names.txt
KHARIF_MODEL_PATH=C:/AI_Preditions/training/image_prediction/runs/kharif/ssgrow_disease_model_v2.keras
KHARIF_CLASS_FILE=C:/AI_Preditions/training/image_prediction/runs/kharif/class_names.txt
RABI_MODEL_PATH=C:/AI_Preditions/training/image_prediction/runs/rabi/ssgrow_disease_model_v2.keras
RABI_CLASS_FILE=C:/AI_Preditions/training/image_prediction/runs/rabi/class_names.txt
MODEL_INPUT_0_255=true
ENABLE_HIERARCHICAL_ROUTING=true
STAGE1_CROP_MODEL_PATH=C:/AI_Preditions/training/hierarchical/artifacts/plant_classifier.pth
STAGE1_CROP_CLASS_FILE=C:/AI_Preditions/training/hierarchical/artifacts/plant_classifier_classes.json
CROP_SPECIFIC_MODELS_DIR=C:/AI_Preditions/training/hierarchical/disease_models
MODEL_CONFIDENCE_TEMPERATURE=1.0
MIN_IMAGE_QUALITY_SCORE=50
MIN_IMAGE_SHARPNESS=20
MAX_IMAGE_GLARE_RATIO=0.12
MAX_IMAGE_DARK_RATIO=0.45
ENABLE_BACKGROUND_SEGMENTATION=true
MIN_SEGMENTED_LEAF_COVERAGE_RATIO=0.08
PESTICIDES_CSV=C:/AI_Preditions/data/outputs/project_data/pesticides_data.csv
ENABLE_AGRONOMY_RETRIEVAL=true
AGRONOMY_DOCS_DIR=C:/AI_Preditions/data/datasets/language_dataset/raw_data
AGRONOMY_RETRIEVAL_MAX_REFERENCES=3
ENABLE_ACTIVE_LEARNING_FALLBACK=true
ACTIVE_LEARNING_DATASET_ROOT=C:/AI_Preditions/data/datasets/active_learning_crops
ACTIVE_LEARNING_MIN_CONFIDENCE=0.50
ENABLE_HEALTHY_LESION_OVERRIDE=true
HEALTHY_VISUAL_BYPASS_CONFIDENCE=95
HEALTHY_LESION_SIGNAL_THRESHOLD=0.55
HEALTHY_LESION_SCORE_THRESHOLD=0.15
HEALTHY_LESION_CONFIDENCE_PENALTY=0.70

# LLM
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
ENABLE_VISION_SUMMARY=false
ENABLE_STRUCTURED_VISUAL_ANALYSIS=true
STRUCTURED_VISUAL_USE_LLM=false

# FastAPI service
FASTAPI_APP_NAME=Sgrow Agricultural AI
FASTAPI_DATABASE_URL=sqlite:///C:/AI_Preditions/ai_backend/fastapi_predictions.db
IMAGE_STORAGE_DIR=C:/AI_Preditions/ai_backend/storage/uploads
